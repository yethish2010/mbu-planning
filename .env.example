# GEMINI_API_KEY: Server-side Gemini key used by backend AI features such as the timetable importer.
# Keep the real value only in .env or your deployment secret manager. Do not commit real keys.
GEMINI_API_KEY="snsn"

# VITE_GEMINI_API_KEY: Optional legacy frontend Gemini key for browser-only AI features.
# Avoid setting this in production because VITE_* values are exposed in browser JavaScript.
VITE_GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# FRONTEND_ORIGIN: Allowed browser origin for a separately hosted frontend.
# Set this when the UI runs on GitHub Pages or another domain and the Node API runs elsewhere.
FRONTEND_ORIGIN="http://localhost:5173"

# VITE_API_BASE_URL: Optional absolute backend URL for static frontend deployments.
# Example for GitHub Pages: "https://your-api-host.example.com"
VITE_API_BASE_URL=""

# VITE_BASE_PATH: Optional subpath for static hosts such as GitHub Pages.
# Example: "/mbu-planning/"
VITE_BASE_PATH="/"

# JWT_SECRET: Used for session authentication.
JWT_SECRET="Secrete_Key"

# DATABASE_PROVIDER: Choose "sqlite" for the existing local file database or "postgres"
# to run the backend against PostgreSQL.
DATABASE_PROVIDER="sqlite"

# DATABASE_PATH: Optional absolute or relative path for the SQLite database file.
# Use a mounted persistent disk path on hosting platforms, for example:
# DATABASE_PATH="/var/data/campus.db"
DATABASE_PATH="./campus.db"

# DATABASE_URL: PostgreSQL connection string used when DATABASE_PROVIDER="postgres".
# Example:
# DATABASE_URL="postgresql://postgres:your%40password@localhost:5432/smart_campus"
DATABASE_URL=""

# PGSSL: Optional PostgreSQL SSL mode override.
# Set PGSSL="disable" for local development against a non-SSL Postgres instance.
PGSSL="disable"
